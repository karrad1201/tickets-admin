# Backend URL (без слеша в конце)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Секрет для подписи httpOnly cookie (минимум 32 символа)
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars

# true в production (cookie только по HTTPS)
AUTH_COOKIE_SECURE=false

# Время жизни cookie в секундах (86400 = 24 часа)
AUTH_COOKIE_MAX_AGE=86400
